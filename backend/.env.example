# InvestiGraph AI — Backend Environment Variables

# Groq API (free) — for LLM agents
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google AI Studio (free) — for embeddings
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Supabase (free tier)
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# JWT — any random string, at least 32 chars
JWT_SECRET=your-random-secret-string-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
